# .athena/Makefile.inc -- generated by athena upgrade
#
# Standard targets for athena-based projects.
# All complex logic lives in the athena CLI; these are thin aliases.
#
# Variables (all use ?= so your Makefile can set them first):
#   ATHENA_PYTHON   Seed interpreter for bootstrap   (default: python3)
#   ATHENA_VENV     Virtual-env directory            (default: venv)
#   ATHENA_CI_VENV  Preflight venv directory         (default: venv-ci)
#   ATHENA_CHECKS   Directory with check scripts     (default: tests/athena)
#   ATHENA_TMPDIR   Temp directory for pip           (default: system tmp)
#   BASELINE_FLAGS  Flags for the baseline runner    (default: common flags)

ATHENA_PYTHON  ?= python3
ATHENA_VENV    ?= venv
ATHENA_CI_VENV ?= venv-ci
ATHENA_CHECKS  ?= tests/athena
BASELINE_FLAGS ?= $(if $(BASELINE),-b) $(if $(VERBOSE),-v) $(if $(ARTIFACTS),-a) $(if $(TIMING),-t)

# Virtual environment -- bootstrap creates a bare venv (layers 0-2: interpreter
# selection, venv creation, pip floor seeding).  fetch_wheel.py handles layer 3
# (install athena from wheel).  athena upgrade handles layers 4-5 (sync config,
# baselines, scaffolding, and install lockfile deps).  Idempotent.
# ATHENA_PYTHON is only a SEED: bootstrap.py probes PATH and re-runs itself
# under the best interpreter satisfying requires-python, so a bare default
# such as `python3` is sufficient even if it is too old.
venv: $(ATHENA_VENV)/bin/activate
$(ATHENA_VENV)/bin/activate: requirements.lock requirements-dev.lock requirements-athena.lock
	@$(ATHENA_PYTHON) .athena/bootstrap.py $(ATHENA_VENV)
	@$(ATHENA_PYTHON) .athena/fetch_wheel.py $(ATHENA_VENV)
	@$(ATHENA_VENV)/bin/athena upgrade $(TAG)

# Bootstrap only -- just get athena CLI available (no lockfile deps).
$(ATHENA_VENV)/bin/athena:
	@$(ATHENA_PYTHON) .athena/bootstrap.py $(ATHENA_VENV)
	@$(ATHENA_PYTHON) .athena/fetch_wheel.py $(ATHENA_VENV)

# Run athena harness checks (quality, dependency audit, contracts)
test-athena: venv
	@$(ATHENA_VENV)/bin/athena test $(BASELINE_FLAGS) $(ATHENA_CHECKS)

# Regenerate lockfiles from pyproject.toml (only needs athena, not full venv)
lock: $(ATHENA_VENV)/bin/athena
	@$(ATHENA_VENV)/bin/athena lock

# Clean generated files
clean:
	rm -rf $(ATHENA_VENV) $(ATHENA_CI_VENV) htmlcov .coverage
	find . -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true
	rm -rf dist/ *.egg-info .athena/output/ .hypothesis/constants/

# Clean, rebuild venv, and run tests
rebuild: clean venv test-athena

# --- Preflight (local CI) ---
# Lockfile-pure venv for pre-push validation. Non-destructive.
# Rebuilds only when lockfiles change.  Delegates to `make venv`
# so the build pathway is not duplicated.
$(ATHENA_CI_VENV)/.stamp: requirements.lock requirements-dev.lock requirements-athena.lock
	@rm -rf $(ATHENA_CI_VENV)
	@$(MAKE) venv ATHENA_VENV=$(ATHENA_CI_VENV)
	@touch $(ATHENA_CI_VENV)/.stamp

preflight: $(ATHENA_CI_VENV)/.stamp  ## Run tests in lockfile-pure venv
	@$(ATHENA_CI_VENV)/bin/athena test $(BASELINE_FLAGS) $(ATHENA_CHECKS)
